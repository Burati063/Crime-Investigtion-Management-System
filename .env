# Example .env file for app/config.py
# Flask/General
SECRET_KEY=your-secret-key
APP_ENV=development
# Or FLASK_ENV=development
# Database (use a valid SQLAlchemy scheme; legacy 'postgres://' will be normalized if present)
DATABASE_URL=postgresql+psycopg2://myuser:mypass@postgres_federal:5432/mydb
# JWT
JWT_SECRET_KEY=your-jwt-secret
JWT_EXPIRES_MINUTES=7000
# File uploads
#UPLOAD_FOLDER=/absolute/path/to/uploads



#front end

NEXT_PUBLIC_API_BASE_URL=http://federal

