# ============================================================
# Root .env — loaded by Docker Compose for ALL services
# ============================================================

# --- Flask Backend ---
SECRET_KEY=your-secret-key
APP_ENV=production
DATABASE_URL=postgresql+psycopg2://myuser:mypass@postgres_federal:5432/mydb
JWT_SECRET_KEY=your-jwt-secret
JWT_EXPIRES_MINUTES=7000
# UPLOAD_FOLDER=/absolute/path/to/uploads   # optional override

# --- Next.js Frontend ---
# NEXT_PUBLIC_ vars are baked into the JS bundle at build time.
# In Docker, the browser hits nginx on port 80, so the origin is http://localhost.
# Do NOT include /api here — every fetch call already appends /api/...
NEXT_PUBLIC_API_BASE_URL=http://localhost

# Server-side (SSR) calls inside the Next.js container go direct to the
# backend container over the internal Docker network.
API_BASE_URL=http://federal:8000
