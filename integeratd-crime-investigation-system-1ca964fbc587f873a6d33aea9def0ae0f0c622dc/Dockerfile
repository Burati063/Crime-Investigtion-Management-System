# syntax=docker/dockerfile:1.6

# ============ Base builder ============
FROM node:20-alpine AS deps
WORKDIR /app
# Install libc6-compat for Next binaries and ensure CA certs are present for HTTPS
RUN apk add --no-cache libc6-compat ca-certificates

# Allow overriding the npm registry (useful behind proxies/firewalls)
ARG NPM_REGISTRY=https://registry.npmjs.org/
ENV NPM_CONFIG_REGISTRY=$NPM_REGISTRY
ENV npm_config_registry=$NPM_REGISTRY

# Only copy package manifests for better build caching
COPY package.json pnpm-lock.yaml* package-lock.json* yarn.lock* ./

# Use npm by default; if pnpm is used, install it and prefer frozen lockfile
RUN npm config set registry "$NPM_REGISTRY" \ 
    && corepack enable \ 
    && corepack prepare pnpm@9.12.1 --activate \ 
    && pnpm config set registry "$NPM_REGISTRY" \ 
    && pnpm config set fetch-retries 5 \ 
    && pnpm config set fetch-retry-factor 2 \ 
    && pnpm config set fetch-retry-mintimeout 10000 \ 
    && pnpm config set fetch-retry-maxtimeout 60000 \ 
    && if [ -f pnpm-lock.yaml ]; then \ 
         echo "Using pnpm with lockfile" && \ 
         PNPM_HOME=$(dirname "$(command -v pnpm)") \ 
         && true \ 
         && pnpm -v \ 
         && --mount=type=cache,id=pnpm-store,target=/root/.pnpm-store pnpm i --frozen-lockfile || pnpm i; \ 
       elif [ -f yarn.lock ]; then \ 
         echo "Using yarn" && yarn config set npmRegistryServer "$NPM_REGISTRY" && yarn install --frozen-lockfile || yarn install; \ 
       elif [ -f package-lock.json ]; then \ 
         echo "Using npm ci" && npm ci; \ 
       else \ 
         echo "Using npm i" && npm i; \ 
       fi

# ============ Production deps (runtime) ============
## Removed separate prod-deps stage; we'll use Next.js standalone output instead

# ============ Builder ============
FROM node:20-alpine AS builder
WORKDIR /app
RUN apk add --no-cache libc6-compat
COPY --from=deps /app/node_modules ./node_modules
COPY . .
# Build Next.js (standalone output)
ARG NEXT_PUBLIC_API_BASE_URL
ARG NEXT_PUBLIC_LOGIN_URL
ENV NEXT_PUBLIC_API_BASE_URL=$NEXT_PUBLIC_API_BASE_URL
ENV NEXT_PUBLIC_LOGIN_URL=$NEXT_PUBLIC_LOGIN_URL
RUN npm run build

# ============ Runtime ============
FROM node:20-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV PORT=3000
RUN addgroup -g 1001 -S nodejs && adduser -S nextjs -u 1001

# Copy the minimal Next.js standalone server and static assets
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static
COPY --from=builder /app/public ./public

# Optional packages needed by some Next.js image features
RUN apk add --no-cache openssl

USER nextjs
EXPOSE 3000
# Run the standalone server (generated by Next.js)
CMD ["node", "server.js"]
